      </tr>
      <tr><td>10/05 12am</td><td>9h</td><td>8h 15m</td><td>45m</td><td class="ok">✓ (15m margin)</td></tr>
      <tr><td>10/05 12am</td><td>12h</td><td>8h 15m</td><td>3h 45m</td><td class="ok">✓</td></tr>
      <tr style="background:rgba(231,76,60,0.06)">
